{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"ignorePatterns": ["node_modules/**", "**/*.d.ts", "**/*.gen.ts", "*.d.ts", "*.gen.ts"],
	"categories": {
		"correctness": "error",
		"suspicious": "error"
	},
	"rules": {
		"eslint/no-console": "error",
		"eslint/no-unused-vars": "warn"
	}
}
